{
  "name": "embrix",
  "version": "1.0.1",
  "description": "Production-ready local text embeddings using @xenova/transformers. Supports MiniLM and BGE models with zero external dependencies.",
  "author": "",
  "license": "MIT",
  "keywords": [
    "embeddings",
    "text-embeddings",
    "transformers",
    "minilm",
    "bge",
    "local-embeddings",
    "semantic-search",
    "vector",
    "nlp",
    "machine-learning"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "benchmark": "npx tsx scripts/benchmark.ts",
    "example": "npx tsx examples/usage.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
